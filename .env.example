AI_GATEWAY_API_KEY=

# --- Phantom Chat / Hermes (self-hosted) gateway ---
# Base URL of your gateway (http/https; ws/wss are auto-converted). The default
# 192.168.68.111:8642 is a LAN address: reachable only from the same network
# (e.g. local `pnpm dev`). For the Vercel deployment, use a public tunnel URL.
OPENCLAW_GATEWAY_BASE_URL=http://192.168.68.111:8642
# Secret gateway token / api_key. Mark as "Secret" in Vercel. Never exposed to
# the client. (Do NOT commit the real value — set it here/locally only.)
OPENCLAW_GATEWAY_TOKEN=
# Default model for gateway requests.
OPENCLAW_MODEL=hermes

# Transport selection: default is "chat" (/v1/chat/completions, this gateway's
# endpoint). Set "auto" to also try /v1/responses, or "responses" to force it.
OPENCLAW_API_MODE=chat

# Secret used to encrypt user-saved settings (e.g. a token entered in the UI)
# at rest. Set a long random value in production. Falls back to other secrets
# if unset, but you SHOULD set this explicitly.
PHANTOM_SETTINGS_SECRET=

# Legacy aliases (still honored): OPENCLAW_GATEWAY_URL, OPENCLAW_CHAT_MODEL
OPENCLAW_GATEWAY_URL=
OPENCLAW_CHAT_MODEL=


# n8n MCP integration
# N8N_MCP_URL is the SSE endpoint exposed by n8n's "MCP Server Trigger" node
# e.g. https://your-n8n.domain.com/mcp/sse  (or the test URL n8n shows)
N8N_MCP_URL=
N8N_API_KEY=
