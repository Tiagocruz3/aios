AI_GATEWAY_API_KEY=

# --- Phantom Chat / OpenClaw (self-hosted) gateway ---
# Base URL of your OpenClaw gateway (http/https; ws/wss are auto-converted).
OPENCLAW_GATEWAY_BASE_URL=https://darkgrey-quail-161852.hostingersite.com
# Secret gateway token. Mark as "Secret" in Vercel. Never exposed to the client.
OPENCLAW_GATEWAY_TOKEN=
# Default model for OpenClaw requests.
OPENCLAW_MODEL=openclaw/default

# Secret used to encrypt user-saved settings (e.g. a token entered in the UI)
# at rest. Set a long random value in production. Falls back to other secrets
# if unset, but you SHOULD set this explicitly.
PHANTOM_SETTINGS_SECRET=

# Legacy aliases (still honored): OPENCLAW_GATEWAY_URL, OPENCLAW_CHAT_MODEL
OPENCLAW_GATEWAY_URL=
OPENCLAW_CHAT_MODEL=


# n8n MCP integration
# N8N_MCP_URL is the SSE endpoint exposed by n8n's "MCP Server Trigger" node
# e.g. https://your-n8n.domain.com/mcp/sse  (or the test URL n8n shows)
N8N_MCP_URL=
N8N_API_KEY=
